---
import { Magnet, ClipboardCheck, Wrench, Sparkles, ChevronDown } from "lucide-astro";

const { currentPath = "/" } = Astro.props;

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

const situationMenu = [
  {
    href: "/plan-action-marketing-tpe",
    label: "Vous manquez de nouveaux clients",
    meta: "Stratégie marketing B2B",
    step: "① ALIMENTER",
    icon: Magnet,
  },
  {
    href: "/suivi-commercial-tpe",
    label: "Vous oubliez de relancer certains prospects",
    meta: "Suivi commercial",
    step: "② PILOTER",
    icon: ClipboardCheck,
  },
  {
    href: "/crm-tpe",
    label: "Vos contacts sont éparpillés partout",
    meta: "CRM & organisation commerciale",
    step: "③ EXÉCUTER",
    icon: Wrench,
  },
  {
    href: "/optimiser-systeme-commercial",
    label: "Votre suivi commercial vous prend trop de temps",
    meta: "IA raisonnée & automatisation",
    step: "④ OPTIMISER",
    icon: Sparkles,
  },
];

const isSituationActive = situationMenu.some((item) => isActive(item.href));
---

<header class="relative z-50 border-b border-[var(--border-soft)] bg-white/80 backdrop-blur md:sticky md:top-0">
  <div
    class="mx-auto grid max-w-6xl items-center px-4 py-3.5 sm:px-6 lg:px-8"
    style="grid-template-columns:auto 1fr auto;"
  >
    <a href="/" class="flex items-center" aria-label="Accueil UpStrategia">
      <img
        src="/images/logo-upstrategia-header.webp"
        alt="UpStrategia - Conseil en suivi commercial et CRM pour TPE et PME"
        width="528"
        height="182"
        decoding="async"
        class="h-[52px] w-auto -translate-y-0.5 object-contain md:h-[60px] md:-translate-y-1 lg:h-[66px] lg:-translate-y-1"
      />
    </a>

    <nav
      class="hidden items-center gap-6 text-sm md:flex"
      aria-label="Navigation principale"
      style="justify-content:center;"
    >
      <div class="relative">
        <details class="group" data-situation-menu-desktop>
 <summary
  aria-label="Menu Quelle est votre situation ?"
  class={`list-none cursor-pointer select-none inline-flex items-center gap-1 font-medium text-[var(--brand-blue)] hover:opacity-80 ${
    isSituationActive ? "font-semibold" : ""
  }`}
>
  <span>Quelle est votre situation ?</span>
 <span class="ml-2 flex h-6 w-6 items-center justify-center rounded-full bg-[var(--bg-soft)]">
  <ChevronDown
    class="h-4 w-4 text-[var(--brand-copper)] transition duration-200 group-open:rotate-180"
  />
</span>
</summary>

          <div class="absolute left-0 mt-3 w-[430px] rounded-2xl border border-[var(--border-soft)] bg-white p-2 shadow-lg">
            {situationMenu.map((item) => {
              const Icon = item.icon;
              const active = isActive(item.href);

              return (
                <a
                  href={item.href}
                  class={`block rounded-xl px-3 py-3 text-sm hover:bg-black/5 ${
                    active ? "bg-[var(--bg-soft)]" : ""
                  }`}
                >
                  <div class="flex gap-3">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[var(--bg-soft)] text-[var(--brand-blue)]">
                      <Icon size={18} />
                    </span>

                    <span>
                      <span class="block text-[10px] font-medium uppercase tracking-[0.12em] text-slate-400">
                        {item.step}
                      </span>

                      <span
                        class={`mt-0.5 block text-base leading-snug text-[var(--brand-blue)] ${
                          active ? "font-bold" : "font-semibold"
                        }`}
                      >
                        {item.label}
                      </span>

                      <span class="mt-1 block text-[11px] font-normal text-slate-400">
                        {item.meta}
                      </span>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        </details>
      </div>

      <a
        href="/offres"
        aria-current={isActive("/offres") ? "page" : undefined}
        class={`font-medium text-[var(--brand-blue)] hover:opacity-80 ${
          isActive("/offres") ? "font-semibold" : ""
        }`}
      >
        Offres
      </a>

      <a
        href="/realisations"
        aria-current={isActive("/realisations") ? "page" : undefined}
        class={`font-medium text-[var(--brand-blue)] hover:opacity-80 ${
          isActive("/realisations") ? "font-semibold" : ""
        }`}
      >
        Réalisations
      </a>

      <a
        href="/blog"
        aria-current={isActive("/blog") ? "page" : undefined}
        class={`font-medium text-[var(--brand-blue)] hover:opacity-80 ${
          isActive("/blog") ? "font-semibold" : ""
        }`}
      >
        Blog
      </a>

    </nav>

    <a
      href="https://calendly.com/carole-yche/rdv-diagnostic-gratuit-clone"
      target="_blank"
      rel="noopener noreferrer"
      class="hidden items-center gap-1 rounded-xl bg-[#9FB09F] px-4 py-2 text-sm font-medium text-[#111111] transition hover:bg-[#92A392] hover:opacity-90 md:inline-flex"
    >
      Réserver 15 min →
    </a>
  </div>

  <nav class="mx-auto max-w-6xl px-4 pb-3 md:hidden" aria-label="Navigation mobile">
    <div class="flex flex-col gap-2 text-sm">
      <div class="rounded-xl border border-[var(--border-soft)] bg-white">
        <details class="group">
          <summary
  class={`flex cursor-pointer list-none items-center justify-between px-4 py-4 hover:bg-black/5 ${
    isSituationActive
      ? "font-semibold text-[var(--text-main)]"
      : "text-[var(--text-muted)]"
  }`}
>
  <span>Quelle est votre situation ?</span>

  <span class="ml-4 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--bg-soft)]">
    <ChevronDown
      aria-hidden="true"
      class="h-5 w-5 text-[var(--brand-copper)] transition duration-200 group-open:rotate-180"
    />
  </span>
</summary>

          <div class="px-2 pb-2">
            {situationMenu.map((item) => {
              const Icon = item.icon;
              const active = isActive(item.href);

              return (
                <a
                  href={item.href}
                  class={`mt-1 block rounded-xl px-2 py-3 hover:bg-black/5 ${
                    active ? "bg-[var(--bg-soft)]" : ""
                  }`}
                >
                  <div class="flex gap-3">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[var(--bg-soft)] text-[var(--brand-blue)]">
                      <Icon size={18} />
                    </span>

                    <span>
                      <span class="block text-[10px] font-medium uppercase tracking-[0.12em] text-slate-400">
                        {item.step}
                      </span>

                      <span
                        class={`mt-0.5 block text-base leading-snug text-[var(--brand-blue)] ${
                          active ? "font-bold" : "font-semibold"
                        }`}
                      >
                        {item.label}
                      </span>

                      <span class="mt-1 block text-[11px] font-normal text-slate-400">
                        {item.meta}
                      </span>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        </details>
      </div>

      <div class="grid grid-cols-2 gap-2">
  <a
    href="/offres"
    class={`rounded-xl border border-[var(--border-soft)] px-3 py-3 text-center hover:bg-black/5 ${
      isActive("/offres")
        ? "font-semibold text-[var(--text-main)]"
        : "text-[var(--text-muted)]"
    }`}
  >
    Offres
  </a>

  <a
    href="/realisations"
    class={`rounded-xl border border-[var(--border-soft)] px-3 py-3 text-center hover:bg-black/5 ${
      isActive("/realisations")
        ? "font-semibold text-[var(--text-main)]"
        : "text-[var(--text-muted)]"
    }`}
  >
    Réalisations
  </a>

  <a
    href="/blog"
    class={`rounded-xl border border-[var(--border-soft)] px-3 py-3 text-center hover:bg-black/5 ${
      isActive("/blog")
        ? "font-semibold text-[var(--text-main)]"
        : "text-[var(--text-muted)]"
    }`}
  >
    Blog
  </a>

  <a
    href="/contact"
    class={`rounded-xl border border-[var(--border-soft)] px-3 py-3 text-center hover:bg-black/5 ${
      isActive("/contact")
        ? "font-semibold text-[var(--text-main)]"
        : "text-[var(--text-muted)]"
    }`}
  >
    Contact
  </a>
</div>

      <a
        href="https://calendly.com/carole-yche/rdv-diagnostic-gratuit-clone"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 inline-flex items-center justify-center rounded-xl bg-[#9FB09F] px-4 py-2.5 text-sm font-medium text-[#111111] transition hover:bg-[#92A392] hover:opacity-90"
      >
        Réserver 15 min →
      </a>
    </div>
  </nav>
</header>

<script>
  const desktopQuery = window.matchMedia("(min-width: 768px)");

  document.querySelectorAll<HTMLDetailsElement>("[data-situation-menu-desktop]").forEach((menu) => {
    let closeTimer: ReturnType<typeof setTimeout> | undefined;

    menu.addEventListener("mouseenter", () => {
      if (closeTimer) clearTimeout(closeTimer);
    });

    menu.addEventListener("mouseleave", () => {
      if (!desktopQuery.matches) return;

      closeTimer = setTimeout(() => {
        if (!menu.matches(":hover")) menu.open = false;
      }, 120);
    });
  });
</script>
